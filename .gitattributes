# Git attributes for consistent line endings across platforms
# Force LF line endings for shell scripts
*.sh text eol=lf

# Force LF for other text files that need Unix line endings
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Let Git handle line endings automatically for source files
*.kt text
*.java text
*.js text
*.jsx text
*.json text
*.md text
*.properties text
*.xml text
*.yml text
*.yaml text

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.woff binary
*.woff2 binary
